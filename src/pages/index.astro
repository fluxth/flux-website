---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <div
    class="bg-[#f0f2f5] min-h-screen flex items-center justify-center p-6 font-sans text-slate-800"
  >
    <div class="max-w-2xl w-full space-y-8">
      <div class="rounded-2xl overflow-hidden border border-slate-300 shadow-2xl bg-white">
        <div
          class="px-5 py-3 bg-gradient-to-b from-slate-500 via-slate-600 to-slate-700 border-b border-slate-800 text-white flex justify-between items-center shadow-[inset_0_1px_0_rgba(255,255,255,0.2)]"
        >
          <span class="font-bold [text-shadow:0_1px_1px_rgba(0,0,0,0.4)] tracking-wide"
            >UNDER CONSTRUCTION</span
          >
        </div>

        <div class="p-10 text-center space-y-8">
          <div
            class="bg-amber-50 border border-amber-300 rounded-lg p-4 flex items-start text-left space-x-3 shadow-sm bg-gradient-to-r from-amber-50 to-white"
          >
            <div
              class="flex-shrink-0 w-6 h-6 rounded-full bg-gradient-to-b from-amber-400 to-amber-600 border border-amber-700 text-white text-xs font-bold flex items-center justify-center font-bold shadow-[inset_0_1px_0_rgba(255,255,255,0.4)]"
            >
              !
            </div>
            <div>
              <h4 class="text-md font-bold text-amber-900 -mt-0.25">Still cooking...</h4>
              <p class="text-sm text-amber-800 leading-relaxed">
                Not sure if I'm too busy or too lazy to finish my homepage, probably the latter
              </p>
            </div>
          </div>

          <div class="pt-1">
            <p class="text-xs font-bold text-slate-400 uppercase mb-4 tracking-widest">
              Reach me on
            </p>
            <div class="flex flex-wrap justify-center gap-3">
              <a
                href="https://github.com/fluxth"
                class="cursor-pointer rounded-lg border border-blue-700 bg-gradient-to-b from-blue-400 via-blue-500 to-blue-600 px-6 py-2.5 font-bold text-white shadow-[inset_0_1px_0_rgba(255,255,255,0.4),0_1px_2px_rgba(0,0,0,0.2)] [text-shadow:0_1px_1px_rgba(0,0,0,0.4)] transition-all hover:from-blue-500 hover:to-blue-700 active:translate-y-[1px] active:shadow-[inset_0_3px_5px_rgba(0,0,0,0.2)] inline-block"
              >
                GitHub
              </a>

              <a
                href="https://linkedin.com/in/fluxth"
                class="ursor-pointer rounded-lg border border-slate-400 bg-gradient-to-b from-white via-slate-50 to-slate-200 px-6 py-2.5 font-bold text-slate-700 shadow-[inset_0_1px_0_white,0_1px_2px_rgba(0,0,0,0.15)] [text-shadow:0_1px_0_white] transition-all hover:from-white hover:to-slate-300 active:translate-y-[1px] active:shadow-[inset_0_3px_5px_rgba(0,0,0,0.1)] inline-block"
              >
                LinkedIn
              </a>
            </div>
          </div>
        </div>

        <div
          class="px-6 py-3 bg-slate-50 border-t border-slate-200 flex items-center justify-between"
        >
          <div class="flex items-center space-x-2"></div>
          <span class="text-[10px] text-slate-400 font-mono">
            <a
              class="underline decoration-dashed underline-offset-2"
              href="https://github.com/fluxth/flux-website">source code</a
            >
          </span>
        </div>
      </div>
    </div>
  </div>
</Layout>
